# ───────────────────────────────────────────────────────────────
# Configuration Docker — git-visualizer
# Copier ce fichier en `.env` puis ajuster :  cp .env.example .env
# ───────────────────────────────────────────────────────────────

# --- Image & conteneur ---
IMAGE_NAME=git-visualizer
IMAGE_TAG=latest
CONTAINER_NAME=git-visualizer

# --- Versions des images de base (args de build) ---
NODE_VERSION=22
NGINX_VERSION=1.27

# --- Production (service `app`) ---
# Port exposé sur la machine hôte → l'app sera sur http://localhost:${HOST_PORT}
HOST_PORT=8080

# --- Développement (service `dev`, profil "dev") ---
# Port interne du serveur Vite et port exposé sur l'hôte
DEV_PORT=5173
DEV_HOST_PORT=5173

# --- Politique de redémarrage des conteneurs ---
# no | always | on-failure | unless-stopped
RESTART_POLICY=unless-stopped
